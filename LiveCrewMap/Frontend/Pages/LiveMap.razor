@page "/"
@inject IJSRuntime JS

<div class="map-container">
    <div id="map"></div>

    <div class="glass-panel main-panel">
        <h3 class="panel-title">Live Crew Map</h3>
        
        @if (!string.IsNullOrEmpty(geoError))
        {
            <div class="geo-alert">
                <strong>Error:</strong> @geoError
                <button class="dismiss-btn" @onclick="() => geoError = null">×</button>
            </div>
        }

        @if (!isClockedIn)
        {
            <div class="input-group">
                <input type="text" @bind="userName" placeholder="Enter your name..." class="glass-input" />
            </div>
            <button class="glass-btn" @onclick="ClockIn" disabled="@(string.IsNullOrWhiteSpace(userName))">
                Clock In
            </button>
        }
        else
        {
            <button class="glass-btn active">
                Clocked In as @userName
            </button>
            <div class="status-group">
                <select class="glass-input status-dropdown" @bind="currentStatus" @bind:after="OnStatusChanged">
                    <option value="Available">🟢 Available</option>
                    <option value="Busy">🟡 Busy</option>
                    <option value="On Route">🔴 On Route</option>
                </select>
                <button class="glass-btn clock-out-btn" style="background: rgba(220, 38, 38, 0.2); border: 1px solid rgba(220, 38, 38, 0.4); color: #f87171;" @onclick="ClockOut">
                    Clock Out
                </button>
            </div>
        }
    </div>

    @if (isClockedIn)
    {
        <div class="glass-panel chat-panel">
            <h3 class="panel-title">Chat</h3>
            <div class="chat-messages">
                @foreach (var msg in chatMessages)
                {
                    <div class="chat-message">
                        <span class="chat-sender">@msg.Sender:</span>
                        <span class="chat-text">@msg.Text</span>
                    </div>
                }
            </div>
            <div class="chat-input-group">
                <input type="text" @bind="chatInput" @bind:event="oninput" @onkeypress="HandleChatKeyPress" class="glass-input" placeholder="Type a message..." />
                <button class="glass-btn" @onclick="SendChatMessage" disabled="@(string.IsNullOrWhiteSpace(chatInput))">Send</button>
            </div>
        </div>
    }
</div>

@code {
    private bool isClockedIn = false;
    private string? userId;
    private string userName = "";
    private IJSObjectReference? module;
    private DotNetObjectReference<LiveMap>? dotNetRef;
#if DEBUG
    private const string BackendWebSocketUrl = "ws://localhost:8787/";
#else
    private const string BackendWebSocketUrl = "wss://api-crewmap.dondlingergc.com/";
#endif

    // New State Properties
    private string currentStatus = "Available";
    private string? geoError;
    private string chatInput = "";
    private List<ChatMessage> chatMessages = new();

    public class ChatMessage
    {
        public string Sender { get; set; } = "";
        public string Text { get; set; } = "";
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var cacheBuster = Guid.NewGuid().ToString();
            module = await JS.InvokeAsync<IJSObjectReference>("import", $"./app.js?v={cacheBuster}");
            await module.InvokeVoidAsync("initMap");
            dotNetRef = DotNetObjectReference.Create(this);

            var storedName = await JS.InvokeAsync<string>("sessionStorage.getItem", "crew_userName");
            var storedId = await JS.InvokeAsync<string>("sessionStorage.getItem", "crew_userId");

            if (!string.IsNullOrEmpty(storedName) && !string.IsNullOrEmpty(storedId))
            {
                userName = storedName;
                userId = storedId;
                isClockedIn = true;
                StateHasChanged();

                await module!.InvokeVoidAsync("startWebSocket", BackendWebSocketUrl, dotNetRef);
                await module.InvokeVoidAsync("startTracking", userId, userName, dotNetRef);
            }
        }
    }

    private async Task ClockIn()
    {
        if (string.IsNullOrWhiteSpace(userName)) return;
        
        isClockedIn = true;
        userId = Guid.NewGuid().ToString();
        
        await JS.InvokeVoidAsync("sessionStorage.setItem", "crew_userName", userName);
        await JS.InvokeVoidAsync("sessionStorage.setItem", "crew_userId", userId);
        
        await module!.InvokeVoidAsync("startWebSocket", BackendWebSocketUrl, dotNetRef);
        await module.InvokeVoidAsync("startTracking", userId, userName, dotNetRef);
    }

    private async Task ClockOut()
    {
        isClockedIn = false;
        await JS.InvokeVoidAsync("sessionStorage.removeItem", "crew_userName");
        await JS.InvokeVoidAsync("sessionStorage.removeItem", "crew_userId");
        await module!.InvokeVoidAsync("stopTracking");
        chatMessages.Clear();
    }

    private async Task OnStatusChanged()
    {
        if (module != null && isClockedIn)
        {
            await module.InvokeVoidAsync("updateStatus", currentStatus);
        }
    }

    private async Task SendChatMessage()
    {
        if (string.IsNullOrWhiteSpace(chatInput) || module == null || !isClockedIn) return;
        
        await module.InvokeVoidAsync("sendChatMessage", chatInput);
        
        chatMessages.Add(new ChatMessage { Sender = userName, Text = chatInput });
        chatInput = "";
        StateHasChanged();
    }

    private async Task HandleChatKeyPress(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await SendChatMessage();
        }
    }

    [JSInvokable]
    public Task ReceiveMessage(object data)
    {
        return Task.CompletedTask;
    }

    [JSInvokable]
    public void ReceiveChatMessage(string sender, string text)
    {
        chatMessages.Add(new ChatMessage { Sender = sender, Text = text });
        StateHasChanged();
    }

    [JSInvokable]
    public void OnGeoError(string message)
    {
        geoError = message;
        StateHasChanged();
    }
}
