@using System.Text.Json
@using Tap.Client.Models
@using Tap.Client.Services
@inject ILocalTimeTrackingService TrackingService
@inject IJSRuntime JSRuntime

<section class="clock-section @(IsClockedIn ? "active-session" : "")">
    <div class="digital-clock">@CurrentTime.ToString("hh:mm:ss tt")</div>
    <div class="date-display">@CurrentTime.ToString("dddd, MMMM dd, yyyy")</div>
    
    <div class="elapsed-time-container">
        <span class="elapsed-label">@(IsClockedIn ? "ACTIVE SESSION TIME" : "LAST SESSION DURATION")</span>
        <div class="elapsed-time">@ElapsedTime.ToString(@"hh\:mm\:ss")</div>
    </div>

    @if (!IsClockedIn && SchemaColumns.Any())
    {
        <div class="custom-fields-container">
            @foreach (var col in SchemaColumns)
            {
                <div class="form-group">
                    <label>@col</label>
                    <input type="text" class="form-control" 
                           @bind="ActiveCustomFields[col]" placeholder="e.g. Work, Study, Project..." />
                </div>
            }
        </div>
    }
    
    <div class="action-buttons">
        @if (!IsClockedIn)
        {
            <button class="btn btn-success" @onclick="ClockIn">
                <span class="icon">▶</span> Clock In
            </button>
        }
        else
        {
            <button class="btn btn-danger" @onclick="ClockOut">
                <span class="icon">■</span> Clock Out
            </button>
        }
    </div>
    
    @if (!string.IsNullOrEmpty(LocationStatus))
    {
        <div class="location-status">
            <span class="dot online" style="width: 5px; height: 5px;"></span>
            <span>@LocationStatus</span>
        </div>
    }
</section>

@code {
    [Parameter]
    public EventCallback OnActivityRecorded { get; set; }

    private DateTime CurrentTime = DateTime.Now;
    private TimeSpan ElapsedTime = TimeSpan.Zero;
    private bool IsClockedIn = false;
    private DateTime? SessionStartTime;
    private System.Threading.Timer? _timer;
    private string LocationStatus = "Location not captured";

    private List<string> SchemaColumns = new();
    private Dictionary<string, string> ActiveCustomFields = new();

    protected override async Task OnInitializedAsync()
    {
        _timer = new System.Threading.Timer(TimerCallback, null, 0, 1000);
        await LoadStateAsync();
    }

    private async Task LoadStateAsync()
    {
        var records = await TrackingService.GetRecordsAsync();
        SchemaColumns = await TrackingService.GetSchemaColumnsAsync();
        
        // Initialize dictionary
        foreach (var col in SchemaColumns)
        {
            if (!ActiveCustomFields.ContainsKey(col))
                ActiveCustomFields[col] = "";
        }

        var activeSession = records.FirstOrDefault(r => r.IsActive);
        
        if (activeSession != null)
        {
            IsClockedIn = true;
            SessionStartTime = activeSession.InTime;
        }
        else
        {
            IsClockedIn = false;
            SessionStartTime = null;
            ElapsedTime = TimeSpan.Zero;
        }
    }

    private async Task ClockIn()
    {
        LocationStatus = "Acquiring GPS...";
        string lat = "Unknown";
        string lng = "Unknown";
        
        try
        {
            var coords = await JSRuntime.InvokeAsync<JsonElement>("tapInterop.getCurrentLocation");
            lat = coords.GetProperty("lat").GetString() ?? "Unknown";
            lng = coords.GetProperty("lng").GetString() ?? "Unknown";
            LocationStatus = $"Captured: {lat}, {lng}";
        }
        catch (Exception ex)
        {
            LocationStatus = "GPS failed: " + ex.Message;
        }

        // Pass a copy of the dictionary
        await TrackingService.ClockInAsync(lat, lng, new Dictionary<string, string>(ActiveCustomFields));
        
        // Clear fields for next clock in
        foreach (var key in ActiveCustomFields.Keys.ToList()) ActiveCustomFields[key] = "";

        await LoadStateAsync();
        await OnActivityRecorded.InvokeAsync();
    }

    private async Task ClockOut()
    {
        await TrackingService.ClockOutAsync();
        await LoadStateAsync();
        await OnActivityRecorded.InvokeAsync();
    }

    private void TimerCallback(object? state)
    {
        CurrentTime = DateTime.Now;
        if (IsClockedIn && SessionStartTime.HasValue)
        {
            ElapsedTime = CurrentTime - SessionStartTime.Value;
        }
        InvokeAsync(StateHasChanged);
    }
}
