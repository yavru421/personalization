@using Tap.Client.Models
@using Tap.Client.Services
@inject ILocalTimeTrackingService TrackingService

<section class="activity-section">
    <div class="activity-header">
        <h2>History</h2>
        @if (Records.Any())
        {
            <button class="btn-danger-outline" @onclick="ClearData">
                Clear All
            </button>
        }
    </div>

    <div class="sync-button-bar">
        <button class="btn btn-outline btn-sm" @onclick="ExportData">
            <span class="sync-icon">⬇</span> Export MD
        </button>
        <div class="file-input-wrapper">
            <button class="btn btn-outline btn-sm" style="width: 100%;">
                <span class="sync-icon">⬆</span> Load MD
            </button>
            <InputFile OnChange="LoadFile" accept=".md" />
        </div>
    </div>
    
    @if (!Records.Any())
    {
        <div class="empty-state">
            <p style="font-weight: 600; margin-bottom: 0.25rem;">No active log file</p>
            <p style="font-size: 0.75rem; color: var(--text-muted); line-height: 1.4;">Upload your record.md file to load previous tracking sessions or clock in to begin.</p>
        </div>
    }
    else
    {
        <div class="session-cards-list">
            @foreach (var record in Records.OrderByDescending(r => r.InTime))
            {
                <div class="session-card @(record.IsActive ? "active" : "")">
                    <div class="session-card-header">
                        <div class="session-time-range">
                            <div class="time-row clock-in">
                                <span style="color: var(--success); font-size: 0.65rem; font-weight: 700; width: 24px;">IN</span>
                                <span>@record.InTime.ToString("MMM d, h:mm tt")</span>
                            </div>
                            <div class="time-row clock-out">
                                <span style="color: @(record.IsActive ? "var(--warning)" : "var(--text-muted)"); font-size: 0.65rem; font-weight: 700; width: 24px;">OUT</span>
                                <span>@(record.IsActive ? "ACTIVE" : record.OutTime!.Value.ToString("MMM d, h:mm tt"))</span>
                            </div>
                        </div>
                        
                        <div class="session-duration">
                            @if (record.IsActive)
                            {
                                <span class="status-badge in-progress">In Progress</span>
                            }
                            else
                            {
                                <div class="duration-val">
                                    @Math.Floor(record.Duration!.Value.TotalHours)h @record.Duration!.Value.Minutes<span>m</span>
                                </div>
                                <span class="status-badge completed">Done</span>
                            }
                        </div>
                    </div>

                    <div class="session-details-grid">
                        <div class="detail-item">
                            <span class="detail-label">Location</span>
                            <span class="detail-val">
                                @if (!string.IsNullOrEmpty(record.Latitude) && record.Latitude != "Unknown")
                                {
                                    <a class="gps-link" href="https://maps.google.com/?q=@record.Latitude,@record.Longitude" target="_blank" rel="noopener">
                                        📍 Map Link
                                    </a>
                                }
                                else
                                {
                                    <span>No GPS</span>
                                }
                            </span>
                        </div>
                        @foreach (var col in SchemaColumns)
                        {
                            <div class="detail-item">
                                <span class="detail-label">@col</span>
                                <span class="detail-val">@(record.CustomFields.ContainsKey(col) && !string.IsNullOrWhiteSpace(record.CustomFields[col]) ? record.CustomFields[col] : "-")</span>
                            </div>
                        }
                    </div>
                </div>
            }
        </div>
    }
</section>

@code {
    [Parameter]
    public List<SessionRecord> Records { get; set; } = new();

    [Parameter]
    public EventCallback OnSyncComplete { get; set; }

    private List<string> SchemaColumns = new();

    protected override async Task OnInitializedAsync()
    {
        SchemaColumns = await TrackingService.GetSchemaColumnsAsync();
    }

    private async Task ExportData()
    {
        var success = await TrackingService.ExportToMarkdownAsync();
        if (success)
        {
            await OnSyncComplete.InvokeAsync();
        }
    }

    private async Task ClearData()
    {
        await TrackingService.ClearAllRecordsAsync();
        await OnSyncComplete.InvokeAsync();
    }

    private async Task LoadFile(InputFileChangeEventArgs e)
    {
        try
        {
            using var stream = e.File.OpenReadStream(maxAllowedSize: 512000); // 500kb max
            using var reader = new System.IO.StreamReader(stream);
            var content = await reader.ReadToEndAsync();
            
            await TrackingService.LoadFromMarkdownAsync(content);
            await OnSyncComplete.InvokeAsync();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error reading file: {ex.Message}");
        }
    }
}
