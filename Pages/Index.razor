@page "/"
@inject HttpClient Http
@inject IJSRuntime JS

<div class="dashboard-wrapper">
    <div class="glass-bg-glow"></div>
    <div class="container-fluid py-4 px-md-5">
        <div class="d-flex justify-content-between align-items-center mb-4 pb-2 border-bottom-glass">
            <div class="brand-header animate-fade-in">
                <span class="badge bg-glass-neon text-cyan text-uppercase tracking-wide mb-1 px-3 py-1.5 rounded-pill font-mono">Dondlinger Tech Platform</span>
                <h1 class="display-6 font-weight-bold text-white mb-0">Universal <span class="text-cyan">Identity & Personalization</span></h1>
            </div>
            
            <div class="d-flex align-items-center gap-3">
                <a href="https://wazweather.dondlingergc.com" class="btn btn-sm btn-outline-info border-glass rounded-pill px-3 text-cyan text-decoration-none">
                    Launch WaZWeather ⟶
                </a>

                <div class="status-indicator-pill px-3 py-1.5 rounded-pill d-flex align-items-center gap-2">
                    <span class="status-dot @(isZlaMode ? "status-zla" : isLoggedIn ? "status-online" : "status-offline")"></span>
                    <span class="text-xs font-mono">
                        @(isZlaMode ? "ZLA (Zero Custody)" : isLoggedIn ? "Cloud Synced" : "Unauthenticated")
                    </span>
                </div>
                
                @if (isLoggedIn)
                {
                    <button class="btn btn-sm btn-outline-danger border-glass rounded-pill px-3" @onclick="Logout">
                        Logout
                    </button>
                }
            </div>
        </div>

        @if (!isLoggedIn)
        {
            <!-- Auth Form Card -->
            <div class="row justify-content-center py-5 animate-scale-in">
                <div class="col-12 col-md-8 col-lg-5">
                    <div class="glass-card shadow-glass p-4 p-md-5">
                        <div class="text-center mb-4">
                            <h2 class="h3 text-white mb-2">@(isRegisterMode ? "Create Account" : "Access Platform Identity")</h2>
                            <p class="text-muted-cyan">@(isRegisterMode ? "Register your Dondlinger Tech Pass for cross-app settings, zero-knowledge vault, and edge quotas" : "Sign in to synchronize settings & credentials across all *.dondlingergc.com applications")</p>
                        </div>


                        @if (!string.IsNullOrEmpty(errorMessage))
                        {
                            <div class="alert alert-danger-glass d-flex align-items-center gap-2 mb-4 animate-shake" role="alert">
                                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0zM12 9v4M12 17h.01"/></svg>
                                <div>@errorMessage</div>
                            </div>
                        }

                        @if (!string.IsNullOrEmpty(successMessage))
                        {
                            <div class="alert alert-success-glass d-flex align-items-center gap-2 mb-4" role="alert">
                                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 11-5.93-9.14M22 4L12 14.01l-3-3"/></svg>
                                <div>@successMessage</div>
                            </div>
                        }

                        <EditForm Model="@authModel" OnValidSubmit="HandleAuthSubmit">
                            <DataAnnotationsValidator />
                            
                            <div class="mb-3">
                                <label for="email" class="form-label text-muted-cyan font-mono text-xs">EMAIL ADDRESS</label>
                                <div class="input-glass-group">
                                    <span class="input-icon"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg></span>
                                    <InputText id="email" class="form-control input-glass" @bind-Value="authModel.Email" placeholder="you@example.com" />
                                </div>
                                <ValidationMessage For="@(() => authModel.Email)" class="text-danger-glass mt-1 text-xs" />
                            </div>

                            <div class="mb-4">
                                <label for="password" class="form-label text-muted-cyan font-mono text-xs">PASSWORD</label>
                                <div class="input-glass-group">
                                    <span class="input-icon"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0110 0v4"/></svg></span>
                                    <InputText type="password" id="password" class="form-control input-glass" @bind-Value="authModel.Password" placeholder="••••••••" />
                                </div>
                                <ValidationMessage For="@(() => authModel.Password)" class="text-danger-glass mt-1 text-xs" />
                            </div>

                            <button type="submit" class="btn btn-cyan btn-glow w-100 py-2.5 rounded-3 mb-3 d-flex align-items-center justify-content-center gap-2" disabled="@isLoading">
                                @if (isLoading)
                                {
                                    <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
                                    <span>Processing...</span>
                                }
                                else
                                {
                                    <span>@(isRegisterMode ? "Register & Setup Sync" : "Sign In to Account")</span>
                                }
                            </button>

                            <div class="text-center">
                                <button type="button" class="btn btn-link text-cyan font-sans text-sm" @onclick="ToggleAuthMode">
                                    @(isRegisterMode ? "Already have an account? Sign In" : "Need an account? Register Here")
                                </button>
                            </div>
                        </EditForm>
                    </div>
                </div>
            </div>
        }
        else
        {
            <!-- Authenticated Dashboard -->
            <div class="row g-4 animate-scale-in">
                <!-- User Profile & API Token Integration Card -->
                <div class="col-12 col-lg-5">
                    <div class="d-flex flex-column gap-4">
                        <!-- Profile Metadata -->
                        <div class="glass-card shadow-glass p-4">
                            <h3 class="h5 text-white mb-3 d-flex align-items-center gap-2">
                                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                                Sync Profile
                            </h3>
                            
                            <div class="profile-grid font-mono">
                                <div class="profile-label text-muted-cyan">ACCOUNT:</div>
                                <div class="profile-value text-white text-truncate">@userProfile.Email</div>
                                
                                <div class="profile-label text-muted-cyan">TIER:</div>
                                <div class="profile-value">
                                    <span class="badge bg-cyan text-dark rounded-pill font-sans">@userProfile.Tier</span>
                                </div>
                                
                                <div class="profile-label text-muted-cyan">STATUS:</div>
                                <div class="profile-value @(isZlaMode ? "text-warning" : "text-green")">
                                    @(isZlaMode ? "Zero Liability Mode" : "Authenticated & Online")
                                </div>
                                
                                <div class="profile-label text-muted-cyan">CREDITS:</div>
                                <div class="profile-value text-cyan">@userProfile.Credits.ToString("N0") units</div>
                            </div>
                        </div>


                    </div>
                </div>

                <!-- Sync Settings Editor Card -->
                <div class="col-12 col-lg-7">
                    <div class="glass-card shadow-glass p-4 h-100 d-flex flex-direction-column">
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <h3 class="h5 text-white mb-0 d-flex align-items-center gap-2">
                                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 00.33 1.82l.06.06a2 2 0 11-2.83 2.83l-.06-.06a1.65 1.65 0 00-1.82-.33 1.65 1.65 0 00-1 1.51V21a2 2 0 01-4 0v-.09A1.65 1.65 0 009 19.4a1.65 1.65 0 00-1.82.33l-.06.06a2 2 0 11-2.83-2.83l.06-.06a1.65 1.65 0 00.33-1.82 1.65 1.65 0 00-1.51-1H3a2 2 0 010-4h.09A1.65 1.65 0 004.6 9a1.65 1.65 0 00-.33-1.82l-.06-.06a2 2 0 112.83-2.83l.06.06a1.65 1.65 0 001.82.33H9a1.65 1.65 0 001-1.51V3a2 2 0 014 0v.09a1.65 1.65 0 001 1.51 1.65 1.65 0 001.82-.33l.06-.06a2 2 0 112.83 2.83l-.06.06a1.65 1.65 0 00-.33 1.82V9a1.65 1.65 0 001.51 1H21a2 2 0 010 4h-.09a1.65 1.65 0 00-1.51 1z"/></svg>
                                Sync Settings
                            </h3>
                            
                            <!-- ZLA Mode Selector Toggle -->
                            <div class="form-check form-switch zla-switch font-mono text-xs d-flex align-items-center gap-2">
                                <input class="form-check-input" type="checkbox" role="switch" id="zlaToggle" @bind="isZlaMode" @bind:after="OnZlaModeChanged" />
                                <label class="form-check-label text-warning" for="zlaToggle">
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="me-1"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>ZLA Mode
                                </label>
                            </div>
                        </div>

                        <div class="settings-sync-status mb-4 p-3 rounded border-glass d-flex align-items-center justify-content-between">
                            <div class="d-flex align-items-center gap-2 text-xs font-mono">
                                <span class="sync-status-icon @(isZlaMode ? "zla" : isSyncPending ? "pending" : "synced")"></span>
                                <span class="text-muted-cyan">
                                    @(isZlaMode ? "State: Zero Custody local storage" : isSyncPending ? "State: Changes pending cloud sync" : $"State: Synchronized with database (D1)")
                                </span>
                            </div>
                            @if (!isZlaMode && isSyncPending)
                            {
                                <button class="btn btn-xs btn-cyan rounded-pill font-mono px-3" @onclick="ForceSettingsSync" disabled="@isSyncing">
                                    @if (isSyncing)
                                    {
                                        <span class="spinner-border spinner-border-xs" role="status" aria-hidden="true"></span>
                                    }
                                    else
                                    {
                                        <span>Sync Now</span>
                                    }
                                </button>
                            }
                        </div>

                        <div class="row g-3 flex-grow-1">
                            <!-- Theme Selection -->
                            <div class="col-12 col-md-6">
                                <label class="form-label text-muted-cyan font-mono text-xs">VISUAL THEME</label>
                                <select class="form-select select-glass" @bind="userSettings.Theme" @bind:after="OnSettingsChanged">
                                    <option value="dark">Vibrant Cyber Dark</option>
                                    <option value="light">Frosted Glass Light</option>
                                    <option value="dracula">Neon Vampire Dracula</option>
                                </select>
                            </div>

                            <!-- Unit preference -->
                            <div class="col-12 col-md-6">
                                <label class="form-label text-muted-cyan font-mono text-xs">MEASUREMENT UNIT</label>
                                <select class="form-select select-glass" @bind="userSettings.Unit" @bind:after="OnSettingsChanged">
                                    <option value="metric">Metric (°C, m/s)</option>
                                    <option value="imperial">Imperial (°F, mph)</option>
                                </select>
                            </div>

                            <!-- Configured Locations -->
                            <div class="col-12">
                                <label class="form-label text-muted-cyan font-mono text-xs d-flex justify-content-between">
                                    <span>MONITORED REGIONS</span>
                                    <span class="text-cyan">@userSettings.Locations.Count / 5</span>
                                </label>
                                
                                <div class="d-flex gap-2 mb-3">
                                    <input type="text" class="form-control input-glass" placeholder="Add location (e.g. Paris, FR)..." @bind="newLocationInput" @onkeyup="HandleLocationKeyup" />
                                    <button class="btn btn-cyan px-3" @onclick="AddLocation">Add</button>
                                </div>

                                <div class="locations-chip-list">
                                    @if (userSettings.Locations == null || userSettings.Locations.Count == 0)
                                    {
                                        <div class="text-muted-cyan text-sm py-2 italic font-sans text-center border-glass-dashed rounded">
                                            No tracking locations configured. Please add a city.
                                        </div>
                                    }
                                    else
                                    {
                                        @foreach (var loc in userSettings.Locations)
                                        {
                                            <span class="location-chip d-inline-flex align-items-center gap-1.5 px-3 py-1.5 rounded-pill font-mono text-xs text-white">
                                                <span>@loc</span>
                                                <button type="button" class="btn-remove-chip" @onclick="() => RemoveLocation(loc)">&times;</button>
                                            </span>
                                        }
                                    }
                                </div>
                            </div>
                        </div>

                        <!-- Sync Status Message Toast / Banner -->
                        @if (!string.IsNullOrEmpty(syncMessage))
                        {
                            <div class="mt-3 alert alert-success-glass py-2 px-3 text-sm font-mono text-center">
                                @syncMessage
                            </div>
                        }
                    </div>
                </div>

                <!-- Edge Stateless Inference Router: URL Evaluator Panel -->
                <div class="col-12 mt-4">
                    <div class="glass-card shadow-glass p-4">
                        <div class="d-flex align-items-center justify-content-between mb-3 border-bottom-glass pb-2">
                            <div>
                                <span class="badge bg-glass-neon text-cyan text-uppercase font-mono text-xs px-2.5 py-1 rounded-pill">Edge Router Feature</span>
                                <h3 class="h5 text-white mb-0 mt-1">Stateless URL Evaluation Router</h3>
                            </div>
                            <span class="text-xs text-muted-cyan font-mono">Model: Llama 3.3 70B Fast Edge</span>
                        </div>

                        <p class="text-muted-cyan text-sm">Paste any public URL below to trigger an edge-native AI architectural and UX evaluation via Cloudflare Workers AI.</p>

                        <div class="d-flex gap-2 mb-3">
                            <input type="url" class="form-control input-glass font-mono text-sm" placeholder="https://wazweather.dondlingergc.com" @bind="evalTargetUrl" />
                            <button class="btn btn-cyan px-4 font-mono text-xs d-flex align-items-center gap-2" @onclick="RunEdgeEvaluation" disabled="@isEvaluating">
                                @if (isEvaluating)
                                {
                                    <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
                                    <span>Evaluating...</span>
                                }
                                else
                                {
                                    <span>Run Edge Eval ⚡</span>
                                }
                            </button>
                        </div>

                        @if (!string.IsNullOrEmpty(evalError))
                        {
                            <div class="alert alert-danger-glass text-xs font-mono mb-3">
                                @evalError
                            </div>
                        }

                        @if (!string.IsNullOrEmpty(evalResult))
                        {
                            <div class="eval-result-card p-3 rounded bg-glass-dark border-glass font-mono text-xs text-cyan-light mt-2" style="white-space: pre-wrap; max-height: 400px; overflow-y: auto;">
                                @evalResult
                            </div>
                        }
                    </div>
                </div>
            </div>
        }
    </div>

</div>
